---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import BlogPostCard from "@/components/BlogPostCard.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
  title="Blog — José Luis Tanicuchí"
  description="Artículos sobre desarrollo web, Laravel, Livewire, Astro y todo lo que voy aprendiendo en el camino."
>
  <main class="max-w-2xl mx-auto px-4 pt-24 pb-16">
    <header class="mb-10">
      <h1 class="text-3xl font-bold mb-2">Blog</h1>
      <p class="text-gray-600 dark:text-gray-400">
        Artículos sobre desarrollo web, herramientas y lo que voy aprendiendo.
      </p>
    </header>

    <div class="flex flex-col gap-4">
      {
        posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
          />
        ))
      }
    </div>
  </main>
</Layout>
