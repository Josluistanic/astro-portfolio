---
interface Props {
  videoId: string;
  title: string;
  description?: string;
  channel?: string;
}

const { videoId, title, description, channel = "YouTube" } = Astro.props;
const url = `https://www.youtube.com/watch?v=${videoId}`;
const thumbnail = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="not-prose flex items-stretch rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden my-6 hover:border-gray-400 dark:hover:border-gray-500 transition-colors no-underline bg-white dark:bg-gray-900"
>
  <div class="flex flex-col justify-between p-4 flex-1 min-w-0">
    <div>
      <p class="font-semibold text-gray-900 dark:text-gray-100 text-sm leading-snug line-clamp-2 mb-1">
        {title}
      </p>
      {
        description && (
          <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-2 mt-1">
            {description}
          </p>
        )
      }
    </div>
    <div class="flex items-center gap-1.5 mt-3">
      <svg
        viewBox="0 0 24 24"
        class="size-4 flex-shrink-0 fill-red-600"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
        ></path>
      </svg>
      <span class="text-xs text-gray-500 dark:text-gray-400 truncate"
        >{channel} &middot; youtube.com</span
      >
    </div>
  </div>
  <div class="w-36 sm:w-48 flex-shrink-0">
    <img src={thumbnail} alt={title} class="w-full h-full object-cover" />
  </div>
</a>
